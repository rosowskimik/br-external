image boot.vfat {
	vfat {
		files = {
#BOOT_FILES#
		}
	}

	size = 32M
}

image sdcard.img {
	hdimage {
		partition-table-type = "hybrid"
	}

	partition efi {
		partition-type-uuid = "esp"
		partition-type = 0xC
		bootable = "true"
		image = "boot.vfat"
	}

	partition rootfs {
		partition-type-uuid = "linux"
		partition-type = 0x83
		image = "rootfs.f2fs"
	}
}
